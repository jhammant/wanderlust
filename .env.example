# Wanderlust Environment Variables
# Copy this file to .env and fill in your values

# AI Provider API Keys (optional - for recommendations)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENROUTER_API_KEY=sk-or-opensrouter-key-here

# Optional: Local AI (Ollama)
# OLLAMA_URL=http://localhost:11434

# Optional: Photos library path (for testing)
# PHOTOS_LIBRARY=/Users/your-username/Pictures/Photos Library.photoslibrary
